{
  "name": "fixtures-ts",
  "version": "0.1.4",
  "description": "Type-safe test fixtures for Jest, Vitest, Bun, and Mocha. Automatic dependency resolution and cleanup with Playwright-style API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "test",
    "fixtures",
    "testing",
    "typescript",
    "test-fixtures",
    "playwright",
    "vitest",
    "bun",
    "jest",
    "mocha",
    "dependency-resolution",
    "test-framework",
    "test-setup",
    "type-safe",
    "beforeEach",
    "afterEach",
    "test-utilities"
  ],
  "author": "Dmitry Demenchuk",
  "license": "MIT",
  "homepage": "https://mrded.github.io/fixtures-ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/mrded/fixtures-ts.git"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {},
  "engines": {
    "node": ">=18.0.0"
  }
}
